# ============================================================
# HTTP Metadata Inventory — Environment Configuration
# ============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# All values shown are defaults. Uncomment and modify as needed.
# ============================================================

# --- Service Identity ---
# SERVICE_NAME=metadata-inventory
# SERVICE_VERSION=0.1.0
# ENVIRONMENT=development          # development | staging | production

# --- HTTP Server ---
# HTTP_PORT=8080
# HTTP_READ_TIMEOUT=15s
# HTTP_WRITE_TIMEOUT=15s
# HTTP_SHUTDOWN_TIMEOUT=30s

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=metadata_inventory
# MONGO_MAX_POOL_SIZE=50
# MONGO_CONN_TIMEOUT=10s

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=url.fetch.requested
# KAFKA_GROUP_ID=metadata-worker-v1
# KAFKA_DLT_TOPIC=url.fetch.failed
# KAFKA_MAX_RETRIES=3

# --- HTTP Fetcher ---
# FETCH_TIMEOUT=30s
# FETCH_MAX_REDIRECTS=10

# --- Logging ---
# LOG_LEVEL=info                   # debug | info | warn | error

# --- Feature Flags ---
# FF_RATE_LIMIT_ENABLED=false
# FF_CIRCUIT_BREAKER_ENABLED=false
# FF_PAGE_SOURCE_STORAGE=true
# FF_ASYNC_FETCH_ONLY=false
# FF_METRICS_ENABLED=true
# FF_TRACING_ENABLED=false

# --- OpenTelemetry (only when FF_TRACING_ENABLED=true) ---
# OTEL_ENDPOINT=localhost:4317
